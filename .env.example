# MU-Bench environment variables.
# Copy to .env and fill in real values. .env is gitignored.
# Only maintainers need the full set; submitters typically need just the
# provider key(s) for the model they're benchmarking, plus HF_TOKEN.

# HuggingFace token used by scripts/download_audio.py to fetch the gated
# sierra-research/mu-bench dataset. Request access at
# https://huggingface.co/datasets/sierra-research/mu-bench
HF_TOKEN=

# OpenAI API key. Used by scripts/transcribe.py when --provider is
# openai-gpt4o-mini-transcribe, and by scoring/normalize.py + scoring/score.py
# (maintainers only — scoring also requires scoring/prompts.py from a
# GitHub secret).
OPENAI_API_KEY=

# Deepgram (Nova-3) — scripts/transcribe.py --provider deepgram-nova3
DEEPGRAM_API_KEY=

# ElevenLabs (Scribe v2) — scripts/transcribe.py --provider elevenlabs-scribe-v2
ELEVENLABS_API_KEY=

# Azure Speech — scripts/transcribe.py --provider azure
AZURE_SPEECH_ENDPOINT=
AZURE_SPEECH_KEY=

# Google Cloud Speech-to-Text v2 (Chirp-3).
# scripts/transcribe.py expects the full service-account JSON as a single-line
# string in GOOGLE_SPEECH_CREDENTIALS (not a file path).
# GOOGLE_SPEECH_REGION is optional. "us" (default) is the multi-region endpoint.
# For strict latency reproducibility, set a specific region like "us-central1".
GOOGLE_SPEECH_CREDENTIALS=
GOOGLE_SPEECH_REGION=us
